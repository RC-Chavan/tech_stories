# Backend environment variables. Copy to .env and fill in.

# Supabase (server-side; service role key bypasses RLS — never expose to browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM (any OpenAI-compatible /chat/completions endpoint)
# Defaults shown below are for MiniMax M3 cloud.
LLM_BASE_URL=https://api.minimax.com/v1
LLM_API_KEY=
LLM_MODEL=minimax-m3

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000

# Misc
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=60

# Email (Resend) — optional. If unset, approval/rejection emails are skipped.
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Incident Stories <noreply@yourdomain.com>
PUBLIC_SITE_URL=http://localhost:3000