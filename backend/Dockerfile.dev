# Backend dev Dockerfile — used by docker-compose.dev.yml.
# Smaller, with uvicorn --reload, source mounted from the host.
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install -r requirements.txt

# Code is bind-mounted from the host in docker-compose.dev.yml — no COPY here.

EXPOSE 8000

# Reload on file changes. Host volume is mounted at /app.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]