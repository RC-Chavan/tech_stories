# ─── LLM (any OpenAI-compatible endpoint) ──────────────────────────────
# Default: MiniMax M3 cloud. Swap freely — see plans/project-plan.md.
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3:4b

# ─── Frontend → backend wiring ─────────────────────────────────────────
# Browser hits the backend on localhost:8000; this is the URL the
# Next.js bundle will call at runtime.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ─── Backend CORS ──────────────────────────────────────────────────────
# Comma-separated origins allowed to call the backend.
ALLOWED_ORIGINS=http://localhost:3000

# ─── Optional ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=60