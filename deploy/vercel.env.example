# Vercel frontend env vars — copy/paste into the Vercel dashboard.
#
# For each var: paste the Value into "Add Environment Variable" → "Value".
# After saving, you MUST trigger a manual redeploy (see deploy/vercel.md).
#
# Where to fetch each value: see deploy/secrets-checklist.md.

# ─── Supabase (browser-exposed, safe to ship) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL = https://oydbjkhudtvseqvgdhy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY = <paste from Supabase → Settings → API → anon (public)>

# ─── Backend URL (⚠️ the most common source of deploy bugs) ─────────────────
# This is the Render URL from Step 2. NO trailing slash.
# Example: https://incident-stories-api.onrender.com
# If `incident-stories-api` was already taken on Render, the URL will have a
# suffix like `-xyz1` — use whatever Render actually gave you.
NEXT_PUBLIC_API_BASE_URL = https://incident-stories-api.onrender.com

# ─── DO NOT ADD ANY OF THESE TO VERCEL ──────────────────────────────────────
# These belong on Render only. Adding them here would either leak the secret
# to every browser or be silently ignored by Next.js.
#
# SUPABASE_SERVICE_ROLE_KEY  ← would leak admin DB access to every visitor
# LLM_BASE_URL                ← backend only
# LLM_API_KEY                 ← backend only
# LLM_MODEL                   ← backend only
# REQUEST_TIMEOUT_SECONDS     ← backend only
# ALLOWED_ORIGINS             ← backend only
# PUBLIC_SITE_URL             ← backend only
# LOG_LEVEL                   ← backend only
# RESEND_API_KEY              ← backend only
# RESEND_FROM_EMAIL           ← backend only
