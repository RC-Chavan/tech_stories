# =============================================================================
# Production env reference — Incident Stories
# =============================================================================
#
# Every env var in the production app, in one place. Read this once; reference
# it whenever you add a new var or someone asks "why is this var set?"
#
# This file is REFERENCE ONLY — it is never read by any process. The two
# dashboards (Render for backend, Vercel for frontend) are the source of truth.
# If something in the repo says one value and Render says another, Render wins.
#
# Legend:
#   🔒 Secret — mark as "Secret" in the dashboard, never commit to git.
#   ⚠️  Build-time — read once during `next build`, baked into the JS bundle.
#                Changing it requires a redeploy, not just an env save.
#   ⏱  Cold-start — on Render free tier, this matters for timeouts.
#
# Where it goes:
#   [Render] → Render web service → Environment tab
#   [Vercel] → Vercel project → Settings → Environment Variables
# =============================================================================

# ─── Supabase (backend only — service role bypasses RLS) ────────────────────
# [Render] 🔒
SUPABASE_URL=
#   Where: Supabase dashboard → Settings → API → Project URL
#   Value: https://oydbjkhudtvseqvgdhy.supabase.co
#   What if missing: backend crashes on startup with pydantic validation error.
#
# [Render] 🔒
SUPABASE_SERVICE_ROLE_KEY=
#   Where: Supabase dashboard → Settings → API → service_role (secret)
#   What if missing: backend crashes on startup.
#   ⚠️  NEVER put this on Vercel — it would leak to every browser that loads
#       the JS bundle, letting anyone bypass RLS and read/write any table.

# ─── LLM (any OpenAI-compatible /chat/completions endpoint) ─────────────────
# [Render]
LLM_BASE_URL=
#   Where: provider dashboard. Currently set to https://openrouter.ai/api/v1
#   What if missing: backend crashes on startup.

# [Render] 🔒
LLM_API_KEY=
#   Where: openrouter.ai → Keys → Create Key (free tier)
#   What if missing: backend crashes on startup.

# [Render]
LLM_MODEL=
#   Where: any model id from https://openrouter.ai/models that has ":free".
#   Free model ids used in production so far:
#     - meta-llama/llama-3.3-70b-instruct:free     (default — 131K context)
#     - qwen/qwen3-next-80b-a3b-instruct:free      (262K context, slower)
#     - openai/gpt-oss-120b:free                   (OpenAI's open-source)
#     - google/gemma-4-31b-it:free                 (262K)
#   Each model has its own quota; swap if you hit 429 rate limits.

# [Render]
REQUEST_TIMEOUT_SECONDS=120
#   Free-tier LLMs are slow — 60s will time out. 120s is the production value.

# ─── CORS + email links ─────────────────────────────────────────────────────
# [Render]
ALLOWED_ORIGINS=
#   Comma-separated origins allowed to call the backend.
#   Single Vercel prod:     https://incident-stories.vercel.app
#   Prod + preview:          https://incident-stories.vercel.app,https://incident-stories-git-main-*.vercel.app
#   ⚠️  No trailing slash. Browsers send Origin without it; mismatch = CORS error.
#   If your site has a custom domain, add that too.

# [Render]
PUBLIC_SITE_URL=
#   Used to build public story links inside email notifications.
#   Should match ALLOWED_ORIGINS (the production one).
#   Leave as http://localhost:3000 if you're skipping Resend for now.

# ─── Logging ────────────────────────────────────────────────────────────────
# [Render]
LOG_LEVEL=INFO
#   Backend default. Set DEBUG for verbose logs (Render free tier will spam you).

# ─── Email (Resend) — optional, leave blank for v0 ─────────────────────────
# [Render] 🔒
RESEND_API_KEY=
#   Where: https://resend.com/api-keys (free tier: 100 emails/day, 3,000/month).
#   What if empty: backend logs a WARN and skips emails. Approval/rejection
#                   notifications are no-ops, but the approve/reject action
#                   itself still works (no email rollback).

# [Render]
RESEND_FROM_EMAIL=
#   Example: "Incident Stories <noreply@yourdomain.com>"
#   Must be on a domain you've verified in Resend.
#   What if empty: same as RESEND_API_KEY — emails silently skipped.

# =============================================================================
# Vercel-only env vars (build-time, baked into the JS bundle)
# =============================================================================

# [Vercel] ⚠️ build-time
NEXT_PUBLIC_SUPABASE_URL=
#   Same value as SUPABASE_URL — the public anon-safe URL.
#   Exposed to the browser (this is fine — it's the public URL).

# [Vercel] ⚠️ build-time
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#   Where: Supabase dashboard → Settings → API → anon (public).
#   This key is safe to ship to the browser — RLS protects your data.

# [Vercel] ⚠️ build-time
NEXT_PUBLIC_API_BASE_URL=
#   The full URL of the Render backend, no trailing slash.
#   Example: https://incident-stories-api.onrender.com
#   ⚠️  This is the most common source of deploy bugs. If the value is
#       wrong/stale, the live site calls the wrong backend and either gets
#       404 (wrong host) or 502/cold-start (right host but unreachable).
#   ⚠️  After saving in Vercel, you MUST trigger a redeploy manually — Vercel
#       does not rebuild on env-var changes.

# =============================================================================
# Local development env vars (for reference — NOT used in prod)
# =============================================================================
#
# Local dev reads from three .env files (NOT committed to git):
#   /Rohit_Interview_Stories/.env                 ← used by docker-compose + frontend build
#   /Rohit_Interview_Stories/backend/.env        ← used by backend container
#   /Rohit_Interview_Stories/frontend/.env.local ← used by frontend dev server
#
# Local values mirror the prod values, with two differences:
#   - SUPABASE_URL etc. point at the same Supabase project (free tier is fine for dev).
#   - NEXT_PUBLIC_API_BASE_URL = http://localhost:8000 (so the browser hits the
#     local docker network). If you see "Missing NEXT_PUBLIC_SUPABASE_URL"
#     errors on the login page, your local .env is empty — copy from
#     .env.example.
