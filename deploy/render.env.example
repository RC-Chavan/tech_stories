# Render backend env vars — copy/paste into the Render dashboard.
#
# For each var: paste the Value into "Add Environment Variable" → "Value".
# Mark SUPABASE_SERVICE_ROLE_KEY and LLM_API_KEY as "Secret" using the eye toggle.
#
# If you're using the Blueprint (deploy/render.yaml), Render fills these in for
# you from the YAML — this file is only needed for the dashboard form path.
#
# Where to fetch each secret value: see deploy/secrets-checklist.md.

# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL = https://oydbjkhudtvseqvgdhy.supabase.co
SUPABASE_SERVICE_ROLE_KEY = <paste from Supabase → Settings → API → service_role>   [Secret]

# ─── LLM (OpenRouter) ───────────────────────────────────────────────────────
LLM_BASE_URL = https://openrouter.ai/api/v1
LLM_API_KEY = <paste from openrouter.ai → Keys → sk-or-v1-...>                     [Secret]
LLM_MODEL = meta-llama/llama-3.3-70b-instruct:free
REQUEST_TIMEOUT_SECONDS = 120

# ─── CORS + email links ─────────────────────────────────────────────────────
# Set this to your real Vercel URL AFTER the Vercel project is created
# (you'll edit it once during Step 4 of the deploy guide).
ALLOWED_ORIGINS = https://incident-stories.vercel.app
PUBLIC_SITE_URL = https://incident-stories.vercel.app

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL = INFO

# ─── Email (Resend) — leave empty for v0 ───────────────────────────────────
RESEND_API_KEY =
RESEND_FROM_EMAIL =
